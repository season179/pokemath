{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pokemath.fun/schemas/question-bank-v2.schema.json",
  "title": "PokeMath question bank v2 (Standard 1)",
  "description": "Additive Std-1 contract: explicit format, TP, presentation, answer form, distractor strategy, bilingual values, and curriculum-profile gates. The runtime parser (shared/question-v2-validate.ts) is the authority; this schema mirrors it for editors and CI. Cross-field rules the schema cannot express (distractor values distinct from the answer, bilingual.numeral matching the answer, duplicate ids, figure coins totaling ≤ 100 sen, crossedOut ≤ count) are enforced by the parser.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "bank_id",
    "version",
    "source",
    "currency",
    "questions"
  ],
  "properties": {
    "schema_version": { "const": 2 },
    "bank_id": { "type": "string", "minLength": 1 },
    "version": { "type": "integer", "minimum": 1 },
    "source": { "type": "string", "minLength": 1 },
    "currency": { "type": "string" },
    "profile": { "$ref": "#/$defs/profile" },
    "scope": { "type": "string", "minLength": 1 },
    "questions": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/question" }
    }
  },
  "$defs": {
    "profile": {
      "description": "Curriculum profile (docs/curriculum/standard-1-sjkc-math.md §1)",
      "enum": ["dpk3_2026_core", "original_dskp_extra"]
    },
    "distractor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["value", "strategy"],
      "properties": {
        "value": { "type": "integer", "minimum": 0 },
        "strategy": {
          "description": "Misconception menu (style doc §D)",
          "enum": [
            "off-by-one-count",
            "count-all-vs-add",
            "wrong-operation",
            "raw-operand",
            "no-carry-concat",
            "digit-reversal",
            "place-value-slip",
            "more-fewer-flip",
            "next-vs-between",
            "clock-hand-swap",
            "word-operator-scramble",
            "money-denom-miscount"
          ]
        }
      }
    },
    "bilingual": {
      "type": "object",
      "additionalProperties": false,
      "required": ["numeral", "zh_word"],
      "properties": {
        "numeral": {
          "type": "string",
          "pattern": "^[0-9]+$",
          "description": "The answer's digits; the parser requires it to equal String(answer)"
        },
        "zh_word": {
          "type": "string",
          "minLength": 1,
          "description": "Chinese number word, e.g. 十八 for 18"
        }
      }
    },
    "question": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "topic",
        "tp_level",
        "profile",
        "item_format",
        "format_type",
        "presentation",
        "answer_form",
        "answer_unit",
        "operation",
        "expression",
        "answer",
        "bilingual",
        "question_zh",
        "question_en",
        "distractors"
      ],
      "properties": {
        "id": { "type": "integer", "minimum": 1 },
        "topic": {
          "description": "Curriculum section (scope doc §4) or the §5 extras bucket",
          "enum": ["4.1", "4.2", "4.3", "4.4", "4.5", "4.6", "4.7", "extra"]
        },
        "tp_level": { "type": "integer", "minimum": 1, "maximum": 6 },
        "profile": { "$ref": "#/$defs/profile" },
        "item_format": {
          "description": "Item shape (style doc §B); v2 serves numeric objective rounds only",
          "const": "objective"
        },
        "format_type": {
          "description": "Worksheet format taxonomy (style doc §A)",
          "enum": [
            "count-write",
            "count-circle",
            "match-connect",
            "color-shade",
            "fill-blank",
            "number-bond",
            "ten-frame",
            "pattern-continue",
            "compare",
            "order-sequence",
            "picture-sentence",
            "word-single",
            "read-instrument",
            "name-count",
            "classify-sort",
            "true-false",
            "trace-write",
            "tally",
            "estimate",
            "round-ten"
          ]
        },
        "presentation": {
          "description": "Presentation axis (style doc §E)",
          "enum": [
            "plain",
            "picture",
            "story",
            "figure:ten-frame",
            "figure:number-bond",
            "figure:number-line",
            "figure:clock",
            "figure:abacus",
            "figure:coins",
            "figure:shapes",
            "figure:pictograph",
            "figure:objects",
            "figure:balance",
            "figure:calendar",
            "figure:grid",
            "figure:table"
          ]
        },
        "answer_form": {
          "description": "Objective forms v2 serves: the numeric forms, circle/true-false (#11), and ordering (#12)",
          "enum": ["numeral", "count", "chinese-word", "circle", "true-false", "ordering"]
        },
        "answer_unit": { "enum": ["none", "RM", "sen"] },
        "operation": {
          "description": "Std-1 hard constraints: counting or + − only",
          "enum": ["counting", "addition", "subtraction"]
        },
        "expression": { "type": "string", "minLength": 1 },
        "answer": { "type": "integer", "minimum": 0 },
        "bilingual": { "$ref": "#/$defs/bilingual" },
        "question_zh": { "type": "string", "minLength": 1 },
        "question_en": { "type": "string", "minLength": 1 },
        "table": {
          "type": "object",
          "additionalProperties": { "type": "number" }
        },
        "distractors": {
          "type": "array",
          "items": { "$ref": "#/$defs/distractor" }
        },
        "sequence": {
          "description": "Declared order for answer_form ordering (#12): items in their CORRECT order plus the direction. Forbidden on every other form. The parser additionally enforces unique values.",
          "$ref": "#/$defs/ordering-sequence"
        },
        "figure": {
          "description": "Declarative figure spec (#16) behind a figure:* presentation; its kind must match the presentation. A figure:* presentation WITHOUT a spec is the deliberate prose fallback, not an error.",
          "$ref": "#/$defs/figure"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": { "answer_form": { "const": "true-false" } },
            "required": ["answer_form"]
          },
          "then": {
            "properties": {
              "answer": {
                "maximum": 1,
                "description": "True-false encodes the answer 1 = 对/✓ (true), 0 = 错/✗ (false)"
              },
              "distractors": {
                "minItems": 1,
                "maxItems": 1,
                "items": {
                  "allOf": [
                    { "$ref": "#/$defs/distractor" },
                    { "properties": { "value": { "maximum": 1 } } }
                  ]
                },
                "description": "Exactly one choice: the opposite truth value (the parser enforces oppositeness)"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "answer_form": { "enum": ["numeral", "count", "chinese-word", "circle"] }
            },
            "required": ["answer_form"]
          },
          "then": {
            "properties": {
              "distractors": {
                "minItems": 3,
                "maxItems": 3,
                "description": "The numeric forms serve a 4-choice round: answer + 3 authored choices"
              }
            }
          }
        },
        {
          "if": {
            "properties": { "answer_form": { "const": "ordering" } },
            "required": ["answer_form"]
          },
          "then": {
            "required": ["sequence"],
            "properties": {
              "distractors": {
                "maxItems": 0,
                "description": "Ordering serves the sequence tiles, not MCQ choices: the list stays empty"
              }
            }
          },
          "else": {
            "not": { "required": ["sequence"] }
          }
        },
        {
          "if": { "required": ["figure"] },
          "then": {
            "description": "figure.kind must match the presentation (the parser enforces the same rule)",
            "anyOf": [
              { "type": "object", "properties": { "figure": { "properties": { "kind": { "const": "ten-frame" } } }, "presentation": { "const": "figure:ten-frame" } } },
              { "type": "object", "properties": { "figure": { "properties": { "kind": { "const": "clock" } } }, "presentation": { "const": "figure:clock" } } },
              { "type": "object", "properties": { "figure": { "properties": { "kind": { "const": "coins" } } }, "presentation": { "const": "figure:coins" } } },
              { "type": "object", "properties": { "figure": { "properties": { "kind": { "const": "objects" } } }, "presentation": { "const": "figure:objects" } } }
            ]
          }
        }
      ]
    },
    "figure": {
      "description": "One declarative figure (#16), discriminated by kind",
      "anyOf": [
        { "$ref": "#/$defs/figure-ten-frame" },
        { "$ref": "#/$defs/figure-clock" },
        { "$ref": "#/$defs/figure-coins" },
        { "$ref": "#/$defs/figure-objects" }
      ]
    },
    "figure-ten-frame": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "filled"],
      "properties": {
        "kind": { "const": "ten-frame" },
        "filled": {
          "type": "integer",
          "minimum": 0,
          "maximum": 20,
          "description": "Counters filling 10-cell frames in reading order; 11..20 draws a second frame (double ten-frame)"
        }
      }
    },
    "figure-clock": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "hour", "minute"],
      "properties": {
        "kind": { "const": "clock" },
        "hour": { "type": "integer", "minimum": 1, "maximum": 12 },
        "minute": {
          "enum": [0, 15, 30, 45],
          "description": "Standard 1 reads whole/half/quarter hours only — the minute hand points at 12, 3, 6, or 9"
        }
      }
    },
    "figure-coins": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "coins"],
      "properties": {
        "kind": { "const": "coins" },
        "coins": {
          "type": "array",
          "minItems": 1,
          "items": { "enum": [5, 10, 20, 50] },
          "description": "Malaysian sen denominations; the parser enforces a total ≤ 100 sen (RM1)"
        }
      }
    },
    "figure-objects": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "icon", "count"],
      "properties": {
        "kind": { "const": "objects" },
        "icon": { "type": "string", "minLength": 1, "description": "One emoji grapheme, e.g. 🐑" },
        "count": { "type": "integer", "minimum": 1, "maximum": 100 },
        "crossedOut": {
          "type": "integer",
          "minimum": 1,
          "description": "Trailing items drawn struck through (picture-sentence subtraction); must be ≤ count (parser-enforced)"
        }
      }
    },
    "ordering-sequence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["direction", "items"],
      "properties": {
        "direction": {
          "description": "ascending/descending order numeric values; forward orders events or pattern stages (labels carry the content)",
          "enum": ["ascending", "descending", "forward"]
        },
        "items": {
          "type": "array",
          "minItems": 3,
          "maxItems": 5,
          "description": "Tiles in their CORRECT order (serving shuffles); values must be unique (parser-enforced)",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["value"],
            "properties": {
              "value": { "type": "integer", "minimum": 0 },
              "label_zh": { "type": "string", "minLength": 1 },
              "label_en": { "type": "string", "minLength": 1 }
            }
          }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": { "direction": { "const": "forward" } },
            "required": ["direction"]
          },
          "then": {
            "description": "Forward events/patterns carry bilingual tile labels",
            "properties": {
              "items": {
                "items": { "required": ["value", "label_zh", "label_en"] }
              }
            }
          }
        }
      ]
    }
  }
}
