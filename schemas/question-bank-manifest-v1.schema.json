{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pokemath.fun/schemas/question-bank-manifest-v1.schema.json",
  "title": "PokeMath question-bank manifest v1",
  "description": "Immutable approval record routing a curriculum slice (grade, topic, TP range, curriculum profile) to one approved bank version (M3, #13). The runtime parser (shared/question-bank-manifest.ts) is the authority; this schema mirrors it for editors and CI. Cross-entry rules the schema cannot express (tp_min <= tp_max, no duplicate bank paths/refs, no overlapping routes) are enforced by the parser.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "manifest_id", "version", "source", "entries"],
  "properties": {
    "schema_version": { "const": 1 },
    "manifest_id": { "type": "string", "minLength": 1 },
    "version": { "type": "integer", "minimum": 1 },
    "source": { "type": "string", "minLength": 1 },
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/entry" }
    }
  },
  "$defs": {
    "entry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["grade", "topic", "tp_min", "tp_max", "profile", "bank_id", "version", "path"],
      "properties": {
        "grade": { "enum": ["std1"] },
        "topic": {
          "enum": ["4.1", "4.2", "4.3", "4.4", "4.5", "4.6", "4.7", "extra"]
        },
        "tp_min": { "type": "integer", "minimum": 1, "maximum": 6 },
        "tp_max": { "type": "integer", "minimum": 1, "maximum": 6 },
        "profile": { "enum": ["dpk3_2026_core", "original_dskp_extra"] },
        "bank_id": { "type": "string", "minLength": 1 },
        "version": { "type": "integer", "minimum": 1 },
        "path": {
          "type": "string",
          "minLength": 1,
          "description": "Cocos resources path of the bank JSON, no extension (e.g. question-banks/std1/woolly-meadows.v1)."
        }
      }
    }
  }
}
