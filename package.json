{
  "name": "pokemath",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "node --test",
    "demo": "node shared/examples/quickstart.ts",
    "review:questions": "node tools/render-question-bank-review.mjs",
    "validate:questions": "node tools/validate-question-bank.mjs",
    "generate:questions": "node tools/generate-question-batch.mjs",
    "review:question-batch": "node tools/review-question-batch.mjs",
    "import:questions": "node tools/import-question-batch.mjs",
    "report:learning": "node tools/render-learning-report.mjs",
    "report:calibration": "node tools/render-calibration-report.mjs",
    "generate:creature": "node tools/generate-creature.mjs",
    "setup-art": "node tools/art-registry.mjs setup",
    "publish-art": "node tools/art-registry.mjs publish",
    "pull-art": "node tools/art-registry.mjs pull",
    "verify-art": "node tools/art-registry.mjs verify",
    "sync": "node tools/sync-shared.mjs",
    "typecheck": "tsc --noEmit -p game/tsconfig.check.json && tsc --noEmit -p worker/tsconfig.json",
    "cf-types": "cd worker && npx wrangler types",
    "check:metas": "node tools/check-missing-metas.mjs",
    "deploy": "cd worker && npx wrangler deploy"
  },
  "devDependencies": {
    "ajv": "^8.20.0",
    "better-sqlite3": "^12.11.1",
    "typescript": "5.5",
    "wrangler": "4.112.0"
  },
  "dependencies": {
    "better-auth": "^1.6.23",
    "sharp": "^0.35.3"
  }
}
